{
    "name": "movie-mogul",
    "version": "1.1.0",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:global": "VITE_SCORES_API=1 vite build",
        "test": "vitest",
        "coverage": "vitest run --coverage",
        "install:browsers": "playwright install chromium webkit firefox",
        "test:e2e": "npm run install:browsers && bddgen && playwright test",
        "test:e2e:ui": "npm run install:browsers && bddgen && playwright test --ui",
        "test:e2e:headed": "npm run install:browsers && bddgen && playwright test --headed",
        "deploy": "./scripts/deploy.sh"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260414.1",
        "@cucumber/cucumber": "^12.7.0",
        "@playwright/test": "^1.58.2",
        "@vitest/coverage-v8": "^4.0.18",
        "playwright-bdd": "^8.4.2",
        "typescript": "^5.9.0",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    }
}
